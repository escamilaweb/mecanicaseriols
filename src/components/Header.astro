---
import { navHref, navLinks, site } from '../data/site';
import SocialLinks from './SocialLinks.astro';

interface Props {
  variant?: 'hero';
}

const { variant = 'hero' } = Astro.props;
const base = import.meta.env.BASE_URL;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const basePath = base.replace(/\/$/, '') || '';
const currentPath = pathname === basePath ? '/' : pathname.replace(basePath, '') || '/';

function isActive(href: string) {
  if (href.includes('#')) return false;
  return currentPath === href || (href !== '/' && currentPath.startsWith(href));
}

const navLinkClass = (href: string) =>
  [
    'header-nav-link text-xs font-semibold uppercase tracking-widest transition-colors',
    {
      'header-nav-link--active': isActive(href),
    },
  ] as const;
---

<header
  id="site-header"
  data-variant={variant}
  class="site-header site-header--dark fixed inset-x-0 top-0 z-50 w-full bg-gradient-to-b from-seriols-dark/85 to-transparent backdrop-blur-sm"
>
  <div class="header-inner mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href={base} class="flex shrink-0 items-center gap-3" aria-label={site.name}>
      <img
        src={`${base}images/Seriols-logo.webp`}
        alt={site.name}
        class="header-logo h-7 w-auto sm:h-8"
        width="180"
        height="28"
      />
    </a>

    <nav aria-label="Navegación principal" class="hidden items-center gap-1 md:flex">
      {
        navLinks.map(({ href, label }) => (
          <a href={navHref(href, base)} class:list={[navLinkClass(href), 'px-3 py-2']}>
            {label}
          </a>
        ))
      }
      <span class="mx-2 hidden h-4 w-px bg-white/15 lg:block" aria-hidden="true"></span>
      <div class="hidden lg:block">
        <SocialLinks variant="header" />
      </div>
    </nav>

    <div class="flex shrink-0 items-center gap-2">
      <div class="hidden md:block lg:hidden">
        <SocialLinks variant="header" />
      </div>
      <a
        href={`${base}contacto/`}
        class="header-cta hidden rounded-full bg-seriols-red px-4 py-2 text-xs font-bold uppercase tracking-wider text-white transition-colors hover:bg-seriols-red-dark sm:inline-flex"
      >
        Pedir cita
      </a>

      <button
        type="button"
        id="nav-toggle"
        class="header-menu-btn inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/20 text-white transition-colors hover:text-white md:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Abrir menú de navegación"
      >
        <svg id="nav-icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg id="nav-icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav"
    class="hidden border-t border-white/10 bg-seriols-dark/95 backdrop-blur-md md:hidden"
    aria-label="Navegación móvil"
  >
    <div class="mx-auto flex max-w-7xl flex-col gap-1 px-4 py-3 sm:px-6">
      {
        navLinks.map(({ href, label }) => (
          <a href={navHref(href, base)} class:list={[navLinkClass(href), 'block px-3 py-2.5']} data-nav-link>
            {label}
          </a>
        ))
      }
      <a
        href={`${base}contacto/`}
        class="mt-2 inline-flex justify-center rounded-full bg-seriols-red px-4 py-2.5 text-xs font-bold uppercase tracking-wider text-white transition-colors hover:bg-seriols-red-dark sm:hidden"
        data-nav-link
      >
        Pedir cita
      </a>
      <div class="mt-4 border-t border-white/10 pt-4">
        <p class="mb-3 px-3 font-mono text-[10px] uppercase tracking-wider text-white/45">Redes sociales</p>
        <div class="px-3">
          <SocialLinks variant="header" closeMenu />
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('nav-icon-open');
  const iconClose = document.getElementById('nav-icon-close');

  let lastScrollY = window.scrollY;
  let ticking = false;

  const closeMenu = () => {
    if (!toggle || !menu || !iconOpen || !iconClose) return;
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Abrir menú de navegación');
    menu.classList.add('hidden');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
  };

  const updateHeaderOnScroll = () => {
    if (!header) return;

    const currentScrollY = window.scrollY;
    const delta = currentScrollY - lastScrollY;
    const atTop = currentScrollY <= 20;

    if (atTop) {
      header.classList.remove('header-hidden', 'header-compact', 'header-scrolled');
    } else {
      header.classList.add('header-scrolled');

      if (delta > 6 && currentScrollY > 72) {
        header.classList.add('header-hidden');
        closeMenu();
      } else if (delta < -6) {
        header.classList.remove('header-hidden');
        header.classList.add('header-compact');
      }
    }

    lastScrollY = currentScrollY;
    ticking = false;
  };

  window.addEventListener(
    'scroll',
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(updateHeaderOnScroll);
    },
    { passive: true },
  );

  if (toggle && menu && iconOpen && iconClose) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú de navegación' : 'Abrir menú de navegación');
      menu.classList.toggle('hidden', !open);
      iconOpen.classList.toggle('hidden', open);
      iconClose.classList.toggle('hidden', !open);
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    menu.querySelectorAll('[data-nav-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    window.matchMedia('(min-width: 768px)').addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  }
</script>

<style>
  .site-header {
    transform: translateY(0);
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      background-color 0.3s ease,
      border-color 0.3s ease;
  }

  .site-header.header-hidden {
    transform: translateY(-100%);
  }

  .site-header.header-scrolled {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(13, 14, 16, 0.97);
    backdrop-filter: blur(12px);
  }

  .header-inner {
    padding-top: 1rem;
    padding-bottom: 1rem;
    transition: padding 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .header-logo,
  .header-cta,
  .header-menu-btn {
    transition:
      height 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      width 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      padding 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-header.header-compact .header-inner {
    padding-top: 0.8125rem;
    padding-bottom: 0.8125rem;
  }

  .site-header.header-compact .header-logo {
    height: 1.625rem;
  }

  @media (min-width: 640px) {
    .site-header.header-compact .header-logo {
      height: 1.875rem;
    }
  }

  .site-header.header-compact .header-cta {
    padding-top: 0.4375rem;
    padding-bottom: 0.4375rem;
  }

  .site-header.header-compact .header-menu-btn {
    height: 2.25rem;
    width: 2.25rem;
  }

  .site-header--dark .header-nav-link {
    color: rgba(255, 255, 255, 0.72);
  }

  .site-header--dark .header-nav-link:hover {
    color: #fff;
  }

  .site-header--dark .header-nav-link--active {
    color: #e20707;
  }
</style>
