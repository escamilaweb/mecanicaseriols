---
import { site } from '../data/site';

const whatsappUrl = `https://wa.me/52${site.whatsapp.replace(/\s/g, '')}?text=${encodeURIComponent('Hola, me gustaría agendar una cita.')}`;
---

<div id="wa-widget" class="wa-widget fixed bottom-5 right-4 z-40 flex flex-col items-end gap-3 sm:bottom-6 sm:right-6">
  <div
    id="wa-greeting"
    class="wa-greeting pointer-events-none hidden max-w-[220px] translate-y-2 opacity-0 transition-all duration-300 sm:max-w-[240px]"
    role="status"
    aria-live="polite"
    aria-hidden="true"
  >
    <div class="relative rounded-2xl border border-seriols-gray-300/40 bg-white px-4 py-3 pr-9 shadow-lg shadow-seriols-dark/10">
      <button
        type="button"
        id="wa-greeting-close"
        class="absolute right-2 top-2 flex h-6 w-6 items-center justify-center rounded-full text-seriols-gray-500 transition hover:bg-seriols-light hover:text-body-text"
        aria-label="Cerrar mensaje de WhatsApp"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <p class="text-sm leading-snug text-body-text">Hola, ¿cómo podemos ayudarte?</p>
      <span class="absolute -bottom-2 right-6 h-4 w-4 rotate-45 border-b border-r border-seriols-gray-300/40 bg-white"></span>
    </div>
  </div>

  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    id="wa-button"
    class="group relative flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg shadow-[#25D366]/30 transition hover:scale-105 hover:bg-[#20bd5a] focus:outline-none focus:ring-2 focus:ring-[#25D366]/50 focus:ring-offset-2"
    aria-label={`Contactar por WhatsApp al ${site.whatsapp}`}
  >
    <span
      id="wa-badge"
      class="absolute -right-0.5 -top-0.5 hidden h-[18px] w-[18px] items-center justify-center rounded-full bg-seriols-red text-[10px] font-bold text-white"
      aria-hidden="true"
    >1</span>
    <svg class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.884 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
      />
    </svg>
  </a>
</div>

<script>
  const COUNT_KEY = 'wa-prompt-count';
  const SECOND_DUE_KEY = 'wa-second-due-at';
  const FIRST_SHOWN_KEY = 'wa-first-shown-at';

  const MAX_PROMPTS = 2;
  const FIRST_DELAY_MS = 10_000;
  const SECOND_DELAY_MS = 90_000;

  const greeting = document.getElementById('wa-greeting');
  const badge = document.getElementById('wa-badge');
  const closeBtn = document.getElementById('wa-greeting-close');

  let pendingTimer: ReturnType<typeof window.setTimeout> | null = null;

  const getPromptCount = () => {
    const raw = sessionStorage.getItem(COUNT_KEY);
    const count = raw ? Number.parseInt(raw, 10) : 0;
    return Number.isFinite(count) ? count : 0;
  };

  const setPromptCount = (count: number) => {
    sessionStorage.setItem(COUNT_KEY, String(count));
  };

  const clearPendingTimer = () => {
    if (pendingTimer !== null) {
      window.clearTimeout(pendingTimer);
      pendingTimer = null;
    }
  };

  const playSubtleSound = () => {
    try {
      const AudioCtx = window.AudioContext || (window as typeof window & { webkitAudioContext?: typeof AudioContext }).webkitAudioContext;
      if (!AudioCtx) return;

      const ctx = new AudioCtx();
      const oscillator = ctx.createOscillator();
      const gain = ctx.createGain();

      oscillator.type = 'sine';
      oscillator.frequency.setValueAtTime(740, ctx.currentTime);
      oscillator.frequency.exponentialRampToValueAtTime(980, ctx.currentTime + 0.12);

      gain.gain.setValueAtTime(0.0001, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.06, ctx.currentTime + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.35);

      oscillator.connect(gain);
      gain.connect(ctx.destination);
      oscillator.start(ctx.currentTime);
      oscillator.stop(ctx.currentTime + 0.36);

      oscillator.addEventListener('ended', () => {
        void ctx.close();
      });
    } catch {
      /* Autoplay policies may block audio without prior interaction */
    }
  };

  const showGreeting = () => {
    if (!greeting || !badge) return;

    greeting.classList.remove('hidden');
    greeting.setAttribute('aria-hidden', 'false');
    badge.classList.remove('hidden');
    badge.classList.add('flex');

    requestAnimationFrame(() => {
      greeting.classList.remove('pointer-events-none', 'translate-y-2', 'opacity-0');
      greeting.classList.add('pointer-events-auto', 'translate-y-0', 'opacity-100');
    });
  };

  const hideGreeting = () => {
    if (!greeting || !badge) return;

    greeting.classList.add('pointer-events-none', 'translate-y-2', 'opacity-0');
    greeting.classList.remove('pointer-events-auto', 'translate-y-0', 'opacity-100');
    greeting.setAttribute('aria-hidden', 'true');
    badge.classList.add('hidden');
    badge.classList.remove('flex');

    window.setTimeout(() => {
      greeting.classList.add('hidden');
    }, 300);
  };

  const scheduleSecondPrompt = (dueAt: number) => {
    sessionStorage.setItem(SECOND_DUE_KEY, String(dueAt));
    clearPendingTimer();

    const remaining = dueAt - Date.now();
    pendingTimer = window.setTimeout(
      () => {
        triggerPrompt();
      },
      remaining > 0 ? remaining : 400,
    );
  };

  const triggerPrompt = () => {
    if (getPromptCount() >= MAX_PROMPTS) return;

    const countBefore = getPromptCount();
    showGreeting();
    playSubtleSound();
    setPromptCount(countBefore + 1);

    if (countBefore === 0) {
      sessionStorage.setItem(FIRST_SHOWN_KEY, String(Date.now()));
    }
  };

  const initPrompts = () => {
    clearPendingTimer();

    const count = getPromptCount();
    if (count >= MAX_PROMPTS) return;

    const secondDueRaw = sessionStorage.getItem(SECOND_DUE_KEY);

    if (count === 0) {
      pendingTimer = window.setTimeout(triggerPrompt, FIRST_DELAY_MS);
      return;
    }

    if (count === 1 && secondDueRaw) {
      scheduleSecondPrompt(Number.parseInt(secondDueRaw, 10));
      return;
    }

    if (count === 1) {
      const firstShownRaw = sessionStorage.getItem(FIRST_SHOWN_KEY);
      if (firstShownRaw) {
        const dueAt = Number.parseInt(firstShownRaw, 10) + SECOND_DELAY_MS;
        scheduleSecondPrompt(dueAt);
      }
    }
  };

  closeBtn?.addEventListener('click', (event) => {
    event.preventDefault();
    event.stopPropagation();
    hideGreeting();

    const count = getPromptCount();
    if (count === 1) {
      scheduleSecondPrompt(Date.now() + SECOND_DELAY_MS);
    }
  });

  initPrompts();
</script>
