---
import { navLinks, site } from '../data/site';
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-brand">{site.name}</p>
      <p class="footer-text">{site.description}</p>
    </div>
    <div>
      <p class="footer-heading">Enlaces</p>
      <ul class="footer-links">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a href={href === '/' ? base : `${base}${href.slice(1)}/`}>{label}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <p class="footer-heading">Contacto</p>
      <ul class="footer-links">
        <li><a href={`tel:${site.phone.replace(/\s/g, '')}`}>{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li>{site.address}</li>
        <li>{site.schedule}</li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} {site.name}. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
    padding-block: 3rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .footer-brand {
    font-weight: 800;
    font-size: 1.125rem;
    margin: 0 0 0.5rem;
  }

  .footer-text {
    color: var(--color-text-muted);
    margin: 0;
    max-width: 28rem;
  }

  .footer-heading {
    font-weight: 600;
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    padding-block: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
</style>
