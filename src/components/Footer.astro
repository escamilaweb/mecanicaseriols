---
import { navHref, navLinks, site } from '../data/site';
import SocialLinks from './SocialLinks.astro';

const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-seriols-gray-300/40 bg-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:px-6 lg:grid-cols-3 lg:px-8">
    <div>
      <img
        src={`${base}images/Seriols-logo.webp`}
        alt={site.name}
        class="mb-4 h-7 w-auto"
        width="160"
        height="24"
      />
      <p class="max-w-xs text-sm text-body-text">{site.description}</p>
    </div>

    <div>
      <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-widest text-seriols-gray-900">
        Enlaces
      </p>
      <ul class="space-y-2">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={navHref(href, base)}
                class="text-sm text-body-text transition hover:text-seriols-red"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-widest text-seriols-gray-900">
        Contacto
      </p>
      <ul class="space-y-2 text-sm text-body-text">
        <li>
          <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="hover:text-seriols-red">
            {site.phone}
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`} class="hover:text-seriols-red">{site.email}</a>
        </li>
        <li>{site.address}</li>
        <li class="pt-3">
          <p class="mb-2 font-mono text-[11px] uppercase tracking-wider text-seriols-gray-900">Redes sociales</p>
          <SocialLinks variant="footer" />
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-seriols-gray-300/40 py-4">
    <p class="text-center text-xs text-seriols-gray-900">
      &copy; <span data-footer-year></span> {site.name}. Todos los derechos reservados.
      <span class="mx-2 text-seriols-gray-300">|</span>
      by{' '}
      <a
        href="https://cbrand.mx/"
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium text-body-text transition hover:text-seriols-red"
      >
        cBrandMX
      </a>
    </p>
  </div>
</footer>

<script is:inline>
  document.querySelectorAll('[data-footer-year]').forEach((el) => {
    el.textContent = String(new Date().getFullYear());
  });
</script>
