---
interface Props {
  class?: string;
  delay?: number;
  tag?: keyof HTMLElementTagNameMap;
}

const { class: className = '', delay = 0, tag: Tag = 'div' } = Astro.props;
---

<Tag
  class:list={['reveal-on-scroll opacity-0 translate-y-6 transition-all duration-700 ease-out', className]}
  data-reveal
  style={`transition-delay: ${delay}ms`}
>
  <slot />
</Tag>
