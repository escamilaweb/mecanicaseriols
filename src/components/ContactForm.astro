---
const labelClass = 'flex flex-col gap-1.5 text-sm font-medium text-body-text';
const apiUrl = `${import.meta.env.BASE_URL}api/contact/`;

const fields = [
  { name: 'name', label: 'Nombre', type: 'text', autocomplete: 'name', placeholder: 'Tu nombre', cols: 2, maxLength: 120 },
  { name: 'phone', label: 'Teléfono', type: 'tel', autocomplete: 'tel', placeholder: '55 1234 5678', cols: 2, maxLength: 30 },
  { name: 'email', label: 'Email', type: 'email', autocomplete: 'email', placeholder: 'tu@email.com', cols: 2, maxLength: 254 },
  {
    name: 'carBrand',
    label: 'Marca de tu auto',
    type: 'text',
    autocomplete: 'off',
    placeholder: 'Ej. Toyota, Nissan…',
    cols: 2,
    maxLength: 80,
  },
  {
    name: 'message',
    label: 'Mensaje',
    type: 'textarea',
    autocomplete: 'off',
    placeholder: '¿En qué podemos ayudarte?',
    cols: 1,
    maxLength: 4000,
  },
] as const;
---

<form id="contact-form" class="flex flex-col gap-4" novalidate>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      fields
        .filter((f) => f.cols === 2)
        .map((field) => (
          <label class={labelClass} data-field={field.name}>
            <span>
              {field.label}
              <span class="text-seriols-red" aria-hidden="true">
                {' '}
                *
              </span>
            </span>
            <input
              type={field.type}
              name={field.name}
              required
              maxlength={field.maxLength}
              autocomplete={field.autocomplete}
              placeholder={field.placeholder}
              class="contact-input"
              data-input={field.name}
              aria-describedby={`error-${field.name}`}
            />
            <span id={`error-${field.name}`} class="contact-field-error hidden" data-error={field.name} role="alert" />
          </label>
        ))
    }
  </div>

  {
    fields
      .filter((f) => f.type === 'textarea')
      .map((field) => (
        <label class={labelClass} data-field={field.name}>
          <span>
            {field.label}
            <span class="text-seriols-red" aria-hidden="true">
              {' '}
              *
            </span>
          </span>
          <textarea
            name={field.name}
            rows="4"
            required
            maxlength={field.maxLength}
            placeholder={field.placeholder}
            class="contact-input"
            data-input={field.name}
            aria-describedby={`error-${field.name}`}
          />
          <span id={`error-${field.name}`} class="contact-field-error hidden" data-error={field.name} role="alert" />
        </label>
      ))
  }

  <p id="contact-form-status" class="hidden text-sm" role="status" aria-live="polite"></p>

  <button
    type="submit"
    id="contact-form-submit"
    class="rounded-full bg-seriols-red px-6 py-3 text-sm font-bold uppercase tracking-wider text-white transition hover:bg-seriols-red-dark disabled:cursor-not-allowed disabled:opacity-60"
  >
    Enviar mensaje
  </button>
</form>

<dialog id="contact-success-dialog" class="contact-success-dialog" aria-labelledby="contact-success-title">
  <div class="contact-success-dialog__panel">
    <div
      class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-seriols-red/10 text-seriols-red"
      aria-hidden="true"
    >
      <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
    </div>
    <h2 id="contact-success-title" class="mb-3 text-center text-xl font-bold text-body-text">¡Gracias por escribirnos!</h2>
    <p class="mb-6 text-center text-sm leading-relaxed text-body-text">
      Recibimos tu mensaje con gusto. Un asesor de Mecánica Seriols se pondrá en contacto contigo muy pronto para
      ayudarte con lo que necesites.
    </p>
    <button
      type="button"
      id="contact-success-close"
      class="w-full rounded-full bg-seriols-red px-6 py-3 text-sm font-bold uppercase tracking-wider text-white transition hover:bg-seriols-red-dark"
    >
      Entendido
    </button>
  </div>
</dialog>

<script define:vars={{ apiUrl }}>
  function initContactForm() {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('contact-form-submit');
    const statusEl = document.getElementById('contact-form-status');
    const dialog = document.getElementById('contact-success-dialog');
    const dialogPanel = dialog?.querySelector('.contact-success-dialog__panel');

    if (!(form instanceof HTMLFormElement) || !(submitBtn instanceof HTMLButtonElement)) {
      return;
    }

    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const messages = {
      name: 'Ingresa tu nombre.',
      phone: 'Ingresa tu teléfono.',
      email: 'Ingresa un email válido.',
      carBrand: 'Indica la marca de tu auto.',
      message: 'Escribe tu mensaje.',
    };

    const getInput = (name) => form.querySelector(`[data-input="${name}"]`);
    const getErrorEl = (name) => form.querySelector(`[data-error="${name}"]`);

    const showFieldError = (name, message) => {
      const input = getInput(name);
      const errorEl = getErrorEl(name);
      if (!(input instanceof HTMLElement) || !(errorEl instanceof HTMLElement)) return;

      input.classList.add('is-invalid');
      input.setAttribute('aria-invalid', 'true');
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
    };

    const clearFieldError = (name) => {
      const input = getInput(name);
      const errorEl = getErrorEl(name);
      if (!(input instanceof HTMLElement) || !(errorEl instanceof HTMLElement)) return;

      input.classList.remove('is-invalid');
      input.setAttribute('aria-invalid', 'false');
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
    };

    const clearAllFieldErrors = () => {
      Object.keys(messages).forEach(clearFieldError);
    };

    const setStatus = (message, type) => {
      if (!(statusEl instanceof HTMLElement)) return;
      statusEl.textContent = message;
      statusEl.classList.remove('hidden', 'text-seriols-red', 'text-body-text', 'text-green-700');
      statusEl.classList.add(
        type === 'error' ? 'text-seriols-red' : type === 'success' ? 'text-green-700' : 'text-body-text',
      );
    };

    const validateForm = (payload) => {
      clearAllFieldErrors();
      let firstInvalid = null;

      for (const [name, emptyMessage] of Object.entries(messages)) {
        const value = payload[name] ?? '';
        let invalid = !value;

        if (name === 'email' && value && !emailPattern.test(value)) {
          invalid = true;
        }

        if (invalid) {
          showFieldError(name, emptyMessage);
          if (!firstInvalid) firstInvalid = name;
        }
      }

      if (firstInvalid) {
        const input = getInput(firstInvalid);
        if (input instanceof HTMLElement) input.focus();
        return false;
      }

      return true;
    };

    for (const name of Object.keys(messages)) {
      const input = getInput(name);
      input?.addEventListener('input', () => {
        const value =
          input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement ? input.value.trim() : '';
        if (name === 'email' && value && !emailPattern.test(value)) return;
        if (value) clearFieldError(name);
      });
      input?.addEventListener('blur', () => {
        const value =
          input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement ? input.value.trim() : '';
        if (!value) {
          showFieldError(name, messages[name]);
          return;
        }
        if (name === 'email' && !emailPattern.test(value)) {
          showFieldError(name, messages.email);
        }
      });
    }

    const CLOSE_ANIMATION_MS = 280;

    const finishClose = () => {
      if (!(dialog instanceof HTMLDialogElement) || !(dialogPanel instanceof HTMLElement)) return;

      dialog.classList.remove('is-closing');
      dialogPanel.classList.remove('is-closing');
      if (dialog.open) dialog.close();
    };

    const closeDialog = () => {
      if (!(dialog instanceof HTMLDialogElement) || !(dialogPanel instanceof HTMLElement)) return;
      if (dialog.classList.contains('is-closing')) return;

      dialog.classList.add('is-closing');
      dialogPanel.classList.add('is-closing');

      let finished = false;
      const completeClose = () => {
        if (finished) return;
        finished = true;
        finishClose();
      };

      const onAnimationEnd = (event) => {
        if (event.target !== dialogPanel) return;
        if (event.animationName !== 'contact-dialog-out') return;
        dialogPanel.removeEventListener('animationend', onAnimationEnd);
        completeClose();
      };

      dialogPanel.addEventListener('animationend', onAnimationEnd);
      window.setTimeout(completeClose, CLOSE_ANIMATION_MS + 80);
    };

    const openDialog = () => {
      if (!(dialog instanceof HTMLDialogElement) || !(dialogPanel instanceof HTMLElement)) return;
      dialog.classList.remove('is-closing');
      dialogPanel.classList.remove('is-closing');
      dialog.showModal();
    };

    if (dialog instanceof HTMLDialogElement) {
      document.getElementById('contact-success-close')?.addEventListener('click', (event) => {
        event.preventDefault();
        closeDialog();
      });
      dialog.addEventListener('cancel', (event) => {
        event.preventDefault();
        closeDialog();
      });
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) closeDialog();
      });
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const payload = {
        name: String(formData.get('name') ?? '').trim(),
        phone: String(formData.get('phone') ?? '').trim(),
        email: String(formData.get('email') ?? '').trim(),
        carBrand: String(formData.get('carBrand') ?? '').trim(),
        message: String(formData.get('message') ?? '').trim(),
      };

      if (!validateForm(payload)) {
        setStatus('Revisa los campos marcados en rojo.', 'error');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando…';
      setStatus('Enviando tu mensaje…', 'info');

      try {
        const response = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          setStatus(data.error ?? 'No se pudo enviar el mensaje. Intenta de nuevo.', 'error');
          return;
        }

        form.reset();
        clearAllFieldErrors();
        if (statusEl instanceof HTMLElement) {
          statusEl.textContent = '';
          statusEl.classList.add('hidden');
        }

        if (dialog instanceof HTMLDialogElement) {
          openDialog();
        }
      } catch {
        setStatus('Error de conexión. Verifica tu red e intenta de nuevo.', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar mensaje';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }
</script>
