---
import ScrollReveal from '../ui/ScrollReveal.astro';
import { home } from '../../data/home';

const { about, trustStats } = home;
const base = import.meta.env.BASE_URL;
const flags = [`${base}images/flag-checkered-red.svg`, `${base}images/flag-checkered.svg`];
---

<section class="border-y border-seriols-gray-300/30 bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <ScrollReveal class="lg:col-span-5">
        <p class="mb-2 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-seriols-red">
          Ingeniería mecánica
        </p>
        <h2 class="text-3xl font-bold tracking-tight text-body-text sm:text-4xl">
          Especialistas formados en el IPN
        </h2>
        <div class="mt-6 flex items-center gap-4">
          <div class="h-px flex-1 bg-seriols-gray-300"></div>
          <span class="font-mono text-xs uppercase tracking-widest text-seriols-gray-500">Est. confianza</span>
        </div>
      </ScrollReveal>

      <div class="space-y-6 lg:col-span-7">
        {
          about.map((paragraph, i) => (
            <ScrollReveal delay={i * 120}>
              <p class="text-base leading-relaxed text-body-text">{paragraph}</p>
            </ScrollReveal>
          ))
        }

        <div class="grid items-stretch gap-5 pt-4 sm:grid-cols-2">
          {
            trustStats.map((stat, i) => (
              <ScrollReveal delay={300 + i * 150} class="h-full">
                <div class="card-lift group relative flex h-full min-h-[180px] flex-col overflow-hidden rounded-2xl border-2 border-seriols-gray-300/40 bg-gradient-to-br from-white to-[#fdf8f8] p-6 shadow-sm hover:border-seriols-red/40">
                  <img
                    src={flags[i]}
                    alt=""
                    class="pointer-events-none absolute bottom-3 right-3 h-9 w-12 opacity-40 transition-opacity duration-300 group-hover:opacity-60"
                    aria-hidden="true"
                    width="48"
                    height="36"
                  />
                  <p class="relative font-mono text-[40px] font-black leading-none text-seriols-red">{stat.value}</p>
                  <p class="relative mt-3 text-sm font-bold uppercase tracking-wider text-body-text">
                    {stat.label}
                  </p>
                  <p class="relative mt-auto pt-3 text-sm leading-relaxed text-body-text">{stat.highlight}</p>
                </div>
              </ScrollReveal>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
