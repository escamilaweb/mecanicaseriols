---
import ScrollReveal from '../ui/ScrollReveal.astro';
import { faq, faqJsonLd } from '../../data/faq';
import { site } from '../../data/site';

const base = import.meta.env.BASE_URL;
const siteUrl = new URL(base, site.url).href;
const schema = faqJsonLd(siteUrl);
const eyebrow = 'mb-2 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-seriols-red';
---

<section
  class="border-t border-seriols-gray-300/30 bg-seriols-light py-16 sm:py-24"
  aria-labelledby="faq-heading"
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <header class="mb-10 text-center">
        <p class={eyebrow}>Información útil</p>
        <h2 id="faq-heading" class="text-3xl font-bold tracking-tight text-body-text sm:text-4xl">
          {faq.title}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-body-text sm:text-base">
          {faq.subtitle}
        </p>
      </header>
    </ScrollReveal>

    <div class="space-y-3">
      {
        faq.items.map(({ question, answer }, i) => (
          <ScrollReveal delay={i * 60}>
            <details class="group rounded-xl border border-seriols-gray-300/40 bg-white transition-colors open:border-seriols-red/25">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-[17px] font-semibold text-body-text marker:content-none sm:px-6 sm:py-5">
                <span>{question}</span>
                <svg
                  class="h-5 w-5 shrink-0 text-seriols-gray-500 transition-transform duration-300 group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
                </svg>
              </summary>
              <div class="border-t border-seriols-gray-300/30 px-5 pb-5 pt-3 sm:px-6 sm:pb-6">
                <p class="text-[16px] leading-relaxed text-body-text">{answer}</p>
              </div>
            </details>
          </ScrollReveal>
        ))
      }
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</section>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
