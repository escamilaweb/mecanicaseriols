---
import { home } from '../../data/home';

const { brands } = home;
const midpoint = Math.ceil(brands.list.length / 2);
const row1 = brands.list.slice(0, midpoint);
const row2 = brands.list.slice(midpoint);
---

<section class="marquee-section overflow-hidden bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-12 max-w-3xl text-center">
      <p class="mb-2 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-seriols-red">
        Compatibilidad multimarca
      </p>
      <h2 class="mb-4 text-3xl font-bold tracking-tight text-body-text sm:text-4xl">
        {brands.title}
      </h2>
      <p class="text-body-text">{brands.description}</p>
    </div>
  </div>

  <div class="space-y-4">
    <div class="relative">
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-white to-transparent sm:w-24"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-white to-transparent sm:w-24"></div>
      <div class="flex overflow-hidden">
        <div class="marquee-track animate-marquee-left flex shrink-0 gap-3 px-2">
          {
            [...row1, ...row1].map((brand) => (
              <span class="brand-pill shrink-0 cursor-default rounded-full border border-seriols-gray-300/60 bg-seriols-light px-5 py-2 text-sm font-extrabold text-seriols-gray-700 transition-colors hover:border-seriols-gray-500/60 hover:text-seriols-gray-900">
                {brand}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-white to-transparent sm:w-24"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-white to-transparent sm:w-24"></div>
      <div class="flex overflow-hidden">
        <div class="marquee-track animate-marquee-right flex shrink-0 gap-3 px-2">
          {
            [...row2, ...row2].map((brand) => (
              <span class="brand-pill shrink-0 cursor-default rounded-full border border-seriols-gray-300/60 bg-seriols-light px-5 py-2 text-sm font-extrabold text-seriols-gray-700 transition-colors hover:border-seriols-gray-500/60 hover:text-seriols-gray-900">
                {brand}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <p class="mx-auto mt-10 max-w-2xl px-4 text-center text-sm text-body-text">
    {brands.fallback}
  </p>
</section>
