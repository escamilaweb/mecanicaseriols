---
import { home } from '../../data/home';
import { mapsDirectionsUrl, site } from '../../data/site';

const { cta } = home;
const base = import.meta.env.BASE_URL;
const directionsUrl = mapsDirectionsUrl();
---

<section class="bg-seriols-dark py-16 text-white sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center lg:gap-16">
      <div>
        <p class="mb-2 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-seriols-red">
          Contacto directo
        </p>
        <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">{cta.title}</h2>
        <p class="mb-6 text-sm leading-relaxed text-white/60">{cta.note}</p>
        <div class="flex flex-wrap gap-3">
          <a
            href={`tel:${site.phone.replace(/\s/g, '')}`}
            class="inline-flex items-center gap-2 rounded-full bg-seriols-red px-6 py-3 text-sm font-bold uppercase tracking-wider text-white transition hover:bg-seriols-red-dark"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              />
            </svg>
            {site.phone}
          </a>
          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3 text-sm font-bold uppercase tracking-wider text-white transition hover:border-white/40"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              />
            </svg>
            {site.email}
          </a>
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm sm:p-8">
        <h3 class="mb-4 font-mono text-xs uppercase tracking-widest text-seriols-gray-300">
          Datos del taller
        </h3>
        <dl class="space-y-4 text-sm">
          <div>
            <dt class="mb-1 font-mono text-[10px] uppercase tracking-wider text-white/40">Dirección</dt>
            <dd class="text-white/90">{site.address}</dd>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <dt class="mb-1 font-mono text-[10px] uppercase tracking-wider text-white/40">WhatsApp</dt>
              <dd>
                <a
                  href={`https://wa.me/52${site.whatsapp.replace(/\s/g, '')}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-seriols-gray-300 transition hover:text-white"
                >
                  <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.884 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                  </svg>
                  {site.whatsapp}
                </a>
              </dd>
            </div>
            <div>
              <dt class="mb-1 font-mono text-[10px] uppercase tracking-wider text-white/40">Oficina</dt>
              <dd>
                <a
                  href={`tel:${site.phoneOffice.replace(/\s/g, '')}`}
                  class="inline-flex items-center gap-2 text-seriols-gray-300 transition hover:text-white"
                >
                  <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    />
                  </svg>
                  {site.phoneOffice}
                </a>
              </dd>
            </div>
          </div>
          <div class="flex flex-wrap gap-3 pt-2">
            <a
              href={directionsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-seriols-red px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-white transition hover:bg-seriols-red-dark"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
              Cómo llegar
            </a>
            <a
              href={`${base}contacto/`}
              class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-seriols-red transition hover:text-white"
            >
              Ver contacto completo
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
