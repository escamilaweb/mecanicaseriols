---
import { home } from '../../data/home';

const { scheduling } = home;
const base = import.meta.env.BASE_URL;
---

<section class="bg-seriols-light py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="overflow-hidden rounded-2xl border border-seriols-gray-300/50 bg-white shadow-sm">
      <div class="grid lg:grid-cols-2">
        <div class="border-b border-seriols-gray-300/40 p-8 sm:p-10 lg:border-b-0 lg:border-r">
          <p class="mb-2 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-seriols-red">
            Agenda optimizada
          </p>
          <h2 class="mb-6 text-2xl font-bold tracking-tight text-body-text sm:text-3xl">
            {scheduling.title}
          </h2>
          <div class="space-y-4">
            {
              scheduling.paragraphs.map((p) => (
                <p class="text-sm leading-relaxed text-body-text sm:text-base">{p}</p>
              ))
            }
          </div>
        </div>

        <div class="flex flex-col justify-center bg-seriols-dark p-8 text-white sm:p-10">
          <div class="mb-6 font-mono text-xs uppercase tracking-[0.2em] text-seriols-gray-300">
            Flujo de atención
          </div>
          <ol class="space-y-4">
            {
              ['Diagnóstico inicial', 'Presupuesto transparente', 'Reparación certificada', 'Entrega el mismo día*'].map(
                (step, i) => (
                  <li class="flex items-center gap-4">
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-seriols-red font-mono text-sm font-bold text-white">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span class="font-medium">{step}</span>
                  </li>
                ),
              )
            }
          </ol>
          <p class="mt-6 text-xs text-white/75">*Sujeto a complejidad del servicio</p>
          <a
            href={`${base}contacto/`}
            class="mt-8 inline-flex w-fit items-center rounded-full bg-seriols-red px-6 py-3 text-sm font-bold uppercase tracking-wider text-white transition hover:bg-seriols-red-dark"
          >
            Agendar cita
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
