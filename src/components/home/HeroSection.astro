---
import QuickActionPanel from './QuickActionPanel.astro';
import { home } from '../../data/home';

const base = import.meta.env.BASE_URL;
const { hero } = home;
const heroSrc = `${base}images/hero.webp`;
const heroSrcSet = `${base}images/hero-800.webp 800w, ${base}images/hero-1280.webp 1280w, ${heroSrc} 1600w`;
---

<section id="hero-section" class="hero-stage relative overflow-hidden">
  <div
    id="hero-parallax-wrap"
    class="relative flex min-h-0 items-center py-24 sm:py-28 md:py-32 lg:h-[750px] lg:max-h-[750px] lg:py-20"
  >
    <div class="absolute inset-0 overflow-hidden">
      <img
        id="hero-bg-image"
        src={heroSrc}
        srcset={heroSrcSet}
        alt={hero.imageAlt}
        class="hero-bg-img"
        fetchpriority="high"
        width="1280"
        height="720"
        sizes="100vw"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-seriols-dark/95 via-seriols-dark/75 to-seriols-dark/40"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-seriols-dark/80 via-transparent to-seriols-dark/30"></div>
    </div>

    <div class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 lg:h-full lg:px-8">
      <div class="grid items-center gap-10 lg:h-full lg:grid-cols-[minmax(0,13fr)_minmax(0,7fr)] lg:gap-8 xl:gap-10">
        <div class="w-full lg:max-w-none">
          <p class="hero-reveal hero-reveal--1 mb-3 font-mono text-xs font-medium uppercase tracking-[0.2em] text-seriols-gray-300 sm:text-[0.8125rem]">
            {hero.subtitle}
          </p>

          <h1 class="mb-4 max-w-[95%] text-[1.75rem] font-black uppercase leading-[1.1] tracking-[0.02em] text-white sm:text-4xl sm:leading-[1.08] lg:text-[2.625rem] lg:leading-[1.06] xl:text-5xl xl:leading-[1.05] 2xl:text-[3.35rem]">
            {
              hero.headline.map((line, i) => (
                <span
                  class:list={[
                    'hero-reveal block',
                    i === 0 && 'mb-1.5 hero-reveal--2',
                    i === hero.headlineAccent && 'text-seriols-red hero-reveal--3',
                  ]}
                >
                  {line}
                </span>
              ))
            }
          </h1>

          <p class="hero-reveal hero-reveal--4 mb-4 text-sm font-semibold uppercase tracking-[0.12em] text-white/85 sm:text-base lg:text-lg">
            {hero.tagline}
          </p>

          <p class="hero-reveal hero-reveal--5 mb-6 max-w-xl text-sm leading-relaxed text-white/70 sm:max-w-2xl sm:text-base lg:max-w-[90%]">
            {hero.description}
          </p>

          <div class="flex flex-wrap gap-3">
            <a
              href={`${base}contacto/`}
              class="hero-reveal hero-reveal--6 inline-flex items-center rounded-full bg-seriols-gray-300 px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-seriols-dark transition hover:bg-white sm:px-6 sm:py-3 sm:text-sm"
            >
              Pedir cita
            </a>
            <a
              href={`${base}#servicios`}
              class="hero-reveal hero-reveal--7 inline-flex items-center rounded-full border border-white/20 bg-white/5 px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-white backdrop-blur-sm transition hover:border-white/40 hover:bg-white/10 sm:px-6 sm:py-3 sm:text-sm"
            >
              Ver servicios
            </a>
          </div>
        </div>

        <div class="hero-reveal hero-reveal--8 flex justify-center pb-2 lg:justify-end lg:pb-0">
          <QuickActionPanel />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const heroSection = document.getElementById('hero-section');
  const heroWrap = document.getElementById('hero-parallax-wrap');

  if (heroSection && heroWrap) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      heroWrap.style.transform = '';
    } else {
      let smoothY = 0;
      let smoothTilt = 0;
      let smoothScale = 1;
      let rafId = 0;

      const lerp = (current: number, target: number, factor: number) => current + (target - current) * factor;

      const tick = () => {
        const rect = heroSection.getBoundingClientRect();
        const viewportHeight = window.innerHeight;
        const heroHeight = Math.max(rect.height, 1);
        const isVisible = rect.bottom > 0 && rect.top < viewportHeight;

        if (!isVisible) {
          rafId = 0;
          return;
        }

        const scrolled = Math.max(0, -rect.top);
        const progress = Math.min(1, scrolled / (heroHeight * 0.72));
        const eased = 1 - Math.pow(1 - progress, 1.6);

        const targetY = eased * 28;
        const targetTilt = eased * 2.2;
        const targetScale = 1 - eased * 0.014;

        smoothY = lerp(smoothY, targetY, 0.11);
        smoothTilt = lerp(smoothTilt, targetTilt, 0.11);
        smoothScale = lerp(smoothScale, targetScale, 0.11);

        heroWrap.style.transform = `perspective(2000px) translate3d(0, ${smoothY.toFixed(2)}px, 0) rotateX(${smoothTilt.toFixed(3)}deg) scale(${smoothScale.toFixed(4)})`;

        const settled =
          Math.abs(targetY - smoothY) < 0.05 &&
          Math.abs(targetTilt - smoothTilt) < 0.002 &&
          Math.abs(targetScale - smoothScale) < 0.0002;

        rafId = settled ? 0 : requestAnimationFrame(tick);
      };

      const requestTick = () => {
        if (rafId) return;
        rafId = requestAnimationFrame(tick);
      };

      window.addEventListener('scroll', requestTick, { passive: true });
      window.addEventListener('resize', requestTick, { passive: true });
      requestTick();
    }
  }
</script>

<style>
  .hero-stage {
    perspective: 2000px;
    perspective-origin: 50% 38%;
  }

  #hero-parallax-wrap {
    transform-origin: 50% 46%;
    transform-style: preserve-3d;
    backface-visibility: hidden;
    will-change: transform;
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @keyframes hero-reveal {
    from {
      opacity: 0;
      transform: translate3d(0, 0.65rem, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .hero-reveal {
    opacity: 0;
    animation: hero-reveal 1.2s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
  }

  .hero-reveal--1 {
    animation-delay: 0.06s;
  }

  .hero-reveal--2 {
    animation-delay: 0.14s;
    animation-duration: 1.28s;
  }

  .hero-reveal--3 {
    animation-delay: 0.26s;
    animation-duration: 1.28s;
  }

  .hero-reveal--4 {
    animation-delay: 0.38s;
  }

  .hero-reveal--5 {
    animation-delay: 0.5s;
    animation-duration: 1.3s;
  }

  .hero-reveal--6 {
    animation-delay: 0.62s;
  }

  .hero-reveal--7 {
    animation-delay: 0.72s;
  }

  .hero-reveal--8 {
    animation-delay: 0.82s;
    animation-duration: 1.35s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-stage {
      perspective: none;
    }

    #hero-parallax-wrap {
      transform: none !important;
      will-change: auto;
    }

    .hero-reveal {
      opacity: 1 !important;
      animation: none !important;
      transform: none !important;
    }
  }
</style>
