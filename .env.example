# Resend — formulario de contacto (/api/contact/)
# Obtén tu API key en https://resend.com/api-keys
#
# En Cloudflare Workers: Settings → Variables and secrets
# En local: copia .dev.vars.example → .dev.vars
RESEND_API_KEY=re_xxxxxxxx

# Remitente verificado en Resend (dominio o onboarding@resend.dev para pruebas)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Bandeja donde llegan los mensajes del formulario
RESEND_TO_EMAIL=agenda@mecanicaseriols.com
